<style>
  .search-box {
    margin-left: 1rem;
    display: inline-flex;
    align-items: center;
  }

  .search-box form {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
  }

  .search-box .form-control {
    display: inline-block;
    width: 220px;
    border-radius: 999px;
    border: 1px solid #ffc0b9;
    padding: 0.45rem 0.9rem;
  }

  .search-box .form-control:focus {
    border-color: #ff6f61;
    box-shadow: 0 0 0 0.15rem rgba(255, 111, 97, 0.2);
  }

  .search-box .btn-success {
    flex-grow: 0;
    height: 2.45rem;
    max-width: none;
    background-color: #ff6f61;
    border-color: #ff6f61;
    border-radius: 999px;
    padding: 0.45rem 0.95rem;
  }

  .search-box .btn-success:hover {
    background-color: #ff3b2e;
    border-color: #ff3b2e;
  }

  i {
    display: inline;
  }
</style>



<nav class="navbar navbar-expand-md bg-body-tertiary-light border-bottom sticky-top">
  <div class="container-fluid">
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo01"
      aria-controls="navbarTogglerDemo01" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarTogglerDemo01">
      <a class="navbar-brand" href=""><i style="font-size: 1.5rem; font-weight: bold; color: #ff6f61;">StayNest</i>
        </span></a>
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" aria-current="page" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/listings">Listings</a>
        </li>
        <div class="search-box">
          <form role="search">
            <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />

            <button class="btn btn-success" type="submit"><i class="fa-solid fa-magnifying-glass"
                style="margin-left: -0.4rem; font-size: 0.95rem"></i> Search</button>
          </form>
        </div>
      </ul>

      <div class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Nest Your Place</a>
        </li>
        <% if (!currentUser) { %>
          <a class="nav-link" href="/signup">Sign Up</a>
          <a class="nav-link" href="/login">Login</a>
          <% } else { %>
            <a class="nav-link" href="/logout">Logout</a>
            <% } %>
      </div>


      <br />

    </div>
  </div>
</nav>