<% layout("/layouts/boilerplate.ejs") %>
    <div class="row">
        <div class="col-8 offset-2">
            <br /><br />
            <h3>Create a New Listing</h3>
            <form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label needs-validation">Title</label>
                    <input type="text" class="form-control" id="title" name="listings[title]"
                        placeholder="Add a catchy title" required>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label needs-validation">Description</label>
                    <textarea class="form-control" id="description" name="listings[description]" placeholder=""
                        required></textarea>
                </div>

                <div class="mb-3">
                    <label for="upload" class="form-label needs-validation">Upload Image</label>
                    <input type="file" class="form-control" id="upload" name="image" accept="image/*" required>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label needs-validation">Price</label>
                        <input type="number" class="form-control" id="price" name="listings[price]" placeholder="1200"
                            required>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label needs-validation">Country</label>
                        <input type="text" class="form-control" id="country" name="listings[country]"
                            placeholder="India" required>
                    </div>
                </div>

                <div class="mb-3 needs-validation">
                    <label for="location" class="form-label needs-validation">Location</label>
                    <input type="text" class="form-control" id="location" name="listings[location]"
                        placeholder="Jaipur, Rajasthan" required>
                </div>

                <button class="btn btn-dark " type="submit">Add</button>
            </form>
        </div>
    </div>