<% layout("/layouts/boilerplate.ejs") %>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-12 col-md-8 col-lg-6">
        <div style="background:#fff; border-radius:1.25rem; padding:2rem; box-shadow:0 6px 24px rgba(0,0,0,0.09);">
            <h2 style="font-weight:800; font-size:1.4rem; letter-spacing:-0.02em; margin-bottom:0.25rem;">
                <i class="fa-solid fa-house-chimney me-2" style="color:#ff6f61;"></i>Create a New Listing
            </h2>
            <p style="color:#aaa; font-size:0.85rem; margin-bottom:1.5rem;">Fill in the details to list your space on StayNest.</p>

            <form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" id="title" name="listings[title]"
                        placeholder="e.g. Cozy Beachfront Cottage" required>
                    <div class="invalid-feedback">Please enter a title.</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" id="description" name="listings[description]"
                        rows="4" placeholder="Describe your space…" required></textarea>
                    <div class="invalid-feedback">Please enter a description.</div>
                </div>

                <div class="mb-3">
                    <label for="upload" class="form-label">Upload Image</label>
                    <input type="file" class="form-control" id="upload" name="image" accept="image/*" required>
                    <div class="invalid-feedback">Please upload an image.</div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label for="price" class="form-label">Price per night ($)</label>
                        <input type="number" class="form-control" id="price" name="listings[price]"
                            placeholder="1200" min="0" required>
                        <div class="invalid-feedback">Please enter a price.</div>
                    </div>
                    <div class="col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" class="form-control" id="country" name="listings[country]"
                            placeholder="India" required>
                        <div class="invalid-feedback">Please enter a country.</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" class="form-control" id="location" name="listings[location]"
                        placeholder="Jaipur, Rajasthan" required>
                    <div class="invalid-feedback">Please enter a location.</div>
                </div>

                <button class="btn btn-dark w-100" type="submit" style="border-radius:0.6rem; padding:0.65rem;">
                    <i class="fa-solid fa-plus me-1"></i>Add Listing
                </button>
            </form>
        </div>
    </div>
</div>