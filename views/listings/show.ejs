<% layout("/layouts/boilerplate.ejs") %>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-12 col-md-8 col-lg-6">

        <!-- Main Listing Card -->
        <div class="show-card card mb-3">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>"
                style="height: 22rem; object-fit: cover;">
            <div class="card-body p-4">
                <h2 class="fw-800 mb-1" style="font-size:1.5rem; font-weight:800; letter-spacing:-0.02em;">
                    <%= listing.title %>
                </h2>
                <p class="mb-1" style="color:#888; font-size:0.85rem;">
                    Listed by <strong style="color:#555;">@<%= listing.owner?.username || "Unknown host" %></strong>
                </p>
                <hr style="margin: 0.75rem 0; border-color: #f0f0f0;">
                <p style="color:#555; line-height:1.7; font-size:0.9rem;"><%= listing.description %></p>
                <p class="mt-2 mb-0" style="font-size:0.9rem; color:#666;">
                    <i class="fa-solid fa-location-dot me-1" style="color:#ff6f61;"></i>
                    <%= listing.location %>, <%= listing.country %>
                </p>
                <p class="mt-1 mb-0" style="font-size:1.1rem; font-weight:700; color:#222;">
                    &#x24;<%= listing.price.toLocaleString() %><span style="font-weight:400; font-size:0.85rem; color:#888;">/night</span>
                </p>
            </div>
        </div>

        <!-- Owner Actions -->
        <% if (currentUser && listing.owner && String(listing.owner._id || listing.owner) === String(currentUser._id)) { %>
        <div class="d-flex gap-2 mb-4">
            <form method="GET" action="/listings/<%= listing._id %>/edit">
                <button class="btn btn-dark" style="border-radius:0.6rem; padding:0.45rem 1.4rem;">
                    <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                </button>
            </form>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn"
                    style="border:1.5px solid #e0e0e0; border-radius:0.6rem; padding:0.45rem 1.4rem; font-weight:600; transition: background 0.2s, color 0.2s, border-color 0.2s;"
                    onmouseenter="this.style.backgroundColor='#ff3b2e';this.style.color='#fff';this.style.borderColor='#ff3b2e';"
                    onmouseleave="this.style.backgroundColor='';this.style.color='';this.style.borderColor='#e0e0e0';"
                    type="submit">
                    <i class="fa-solid fa-trash-can me-1"></i>Delete
                </button>
            </form>
        </div>
        <% } %>

        <hr style="border-color:#eee;">

        <!-- Reviews -->
        <% if (listing.reviews.length > 0) { %>
            <h3 class="mb-3"><i class="fa-solid fa-star me-2" style="color:#ff6f61; font-size:1rem;"></i>Reviews</h3>
            <% for (let review of listing.reviews) { %>
                <div class="review-card card mb-3 p-3">
                    <p class="starability-result mb-1" data-rating="<%= review.rating %>">
                        Rated: <%= review.rating %> stars
                    </p>
                    <p class="mb-1" style="color:#333; font-size:0.9rem;"><%= review.comment %></p>
                    <p class="mb-0"><small class="text-muted"><%= review.createdAt.toLocaleString() %></small></p>
                    <% if (currentUser && review.author && String(review.author) === String(currentUser._id)) { %>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-2">
                            <button class="btn btn-danger btn-sm" type="submit"
                                style="border-radius:0.5rem; font-size:0.78rem; padding:0.25rem 0.75rem;">
                                <i class="fa-solid fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    <% } %>
                </div>
            <% } %>
            <hr style="border-color:#eee;">
        <% } else { %>
            <p style="color:#aaa; font-size:0.88rem; margin-bottom:1rem;">
                <i class="fa-regular fa-comment me-1"></i>No reviews yet — be the first!
            </p>
        <% } %>

        <!-- Feedback Form -->
        <% if (currentUser) { %>
            <h3 class="mb-3"><i class="fa-solid fa-comment-dots me-2" style="color:#ff6f61; font-size:1rem;"></i>Leave Feedback</h3>
            <form action="/listings/<%= listing._id %>/feedback" method="POST" class="needs-validation mb-4" novalidate
                style="background:#fff; border-radius:1rem; padding:1.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
                <fieldset class="starability-heartbeat mb-3">
                    <legend style="font-size:0.85rem; font-weight:600; color:#555;">Your rating:</legend>
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea class="form-control" id="comment" name="review[comment]" rows="3"
                        placeholder="Share your experience…" required></textarea>
                    <div class="invalid-feedback">Please enter a comment.</div>
                </div>
                <button class="btn btn-dark" type="submit">
                    <i class="fa-solid fa-paper-plane me-1"></i>Submit Review
                </button>
            </form>
            <hr style="border-color:#eee;">
        <% } %>

        <!-- Map -->
        <h3 class="mb-2"><i class="fa-solid fa-map-location-dot me-2" style="color:#ff6f61; font-size:1rem;"></i>Location</h3>
        <div id="map" data-location="<%= listing.location %>" data-country="<%= listing.country %>"
            style="margin-bottom: 2.5rem;"></div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function () {
        const mapContainer = document.getElementById('map');
        if (!mapContainer || typeof L === 'undefined') return;

        const fallbackCoords = [20.5937, 78.9629];
        const locationText = [mapContainer.dataset.location, mapContainer.dataset.country]
            .filter(Boolean).join(', ');

        const map = L.map(mapContainer).setView(fallbackCoords, 3);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        let targetCoords = fallbackCoords, zoomLevel = 3;
        try {
            const response = await fetch(
                `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(locationText)}`
            );
            if (response.ok) {
                const result = await response.json();
                if (result.length > 0) {
                    targetCoords = [parseFloat(result[0].lat), parseFloat(result[0].lon)];
                    zoomLevel = 11;
                }
            }
        } catch (err) { console.error('Location lookup failed:', err); }

        map.setView(targetCoords, zoomLevel);
        L.marker(targetCoords).addTo(map).bindPopup(locationText).openPopup();
    });
</script>