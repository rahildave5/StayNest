<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayNest</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=raven" />
</head>

<body>
    <%- include("../includes/navbar.ejs") %>

        <div class="intro">
            <h2 class="display-5" style="margin-left: 30rem;">Welcome to <b style="color: #ff6f61;">StayNest!</b></h2>
            <p style="text-align: center; "> Your one-stop destination for cozy and affordable stays around the world.
                Whether you're looking for a
                charming cottage, a modern apartment, or a unique treehouse, StayNest has something for everyone.
                Explore our listings and find your perfect getaway today!</p>
        </div>



        <div class=" container mt-4">
            <% if (typeof success !=="undefined" && success && success.length> 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert"
                    style="position: relative; z-index: 1000;">
                    <strong>Success!</strong>
                    <%= success[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>

                    <% if (typeof error !=="undefined" && error && error.length> 0) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert"
                            style="position: relative; z-index: 1000;">
                            <strong>Error!</strong>
                            <%= error[0] %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"></button>
                        </div>
                        <% } %>

                            <%- body %>
        </div>

        <%- include("../includes/footer.ejs") %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
                crossorigin="anonymous"></script>
            <script src="/js/script.js"></script>
</body>

</html>
