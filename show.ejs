<% layout("/layouts/boilerplate.ejs") %>
    <div class="row">
        <div class="col-8 offset-2">
            <br /><br />

        </div>

        <div class="card col-6 offset-3">
            <h3>
                <%= listing.title %>
            </h3>
            <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>" style="height: 20rem; ">
            <div class="card-body">
                <p class="card-text">
                <p>
                    <%= listing.description %>
                </p>
                <%= listing.location %> ,
                    <%= listing.country %> <br />
                        <b>&#x24;<%= listing.price.toLocaleString("en-US") %>/night</b>
                        </p>
            </div>
        </div>

        <div class="col-8 offset-3 ">
            <br />

            <a href="/listings/<%= listing._id %>/edit">Edit the Listing</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="sbtns" type="submit">Delete Listing</button>
            </form>
        </div>

        <div class="col-8   offset-7">


        </div>


    </div>