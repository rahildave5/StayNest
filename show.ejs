<% layout("/layouts/boilerplate.ejs") %>
    <div class="row">
        <div class="col-8 offset-2">
            <br /><br />

        </div>

        <div class="card col-6 offset-3 card">
            <h3>
                <%= listing.title %>
            </h3>
            <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>" style="height: 20rem; ">
            <div class="card-body">
                <p class="card-text">
                <p>
                    <%= listing.description %>
                </p>
                <%= listing.location %> ,
                    <%= listing.country %> <br />
                        <b>&#x24;<%= listing.price.toLocaleString("en-US") %>/night</b>
                        </p>
            </div>
        </div>

        <div style="margin-top:-3rem; display: flex; flex-direction: row;" class=" col-8 offset-3">

            <form method="GET" action="/listings/<%= listing._id %>/edit">
                <button style="height: 2rem; padding: 0.15rem 1rem; border-radius: 0.51rem;" class="btn btn-dark">Edit
                </button>
            </form>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn"
                    style=" margin: 1rem 0 0 1rem; border:1px solid black; height: 2rem; padding: 0.15rem 1rem; border-radius: 0.51rem;"
                    onmouseenter="this.style.backgroundColor = '#ff0000'" onmouseleave="this.style.backgroundColor = ''"
                    class="sbtns" type="submit">Delete
                </button>
            </form>
        </div>

        <div style="margin-top: -2rem;" class="col-8 offset-3">
            <hr />
            <h3>Reviews</h3>
            <div id="reviews-container">
                <!-- Reviews will be dynamically loaded here -->
                <ul>
                    <% if (listing.reviews && listing.reviews.length> 0) { %>
                        <% for(let review of listing.reviews) { %>
                            <div class="card">
                                <div class="card-body">
                                    <h6>@<%= review.username %>
                                    </h6>
                                    <li>
                                        <p class="card-title">Rating: <%= review.rating %>/5</p>
                                    </li>
                                    <li>
                                        <p class="card-text">
                                            <%= review.comment %>
                                        </p>
                                    </li>
                                    <p class="card-text"><small class="text-muted">
                                            <%= review.createdAt.toLocaleString() %>
                                        </small></p>
                                    <form method="POST"
                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                        <button style="height: 1.75rem; width: 4rem; padding: 0px; margin-top: -1rem;"
                                            class="btn btn-danger" type="submit">Delete</button>
                                    </form>
                                    <hr />
                                </div>
                            </div>
                            <% } %>
                                <%} else { %>

                                    <p style="margin-left: -2rem;">No reviews yet. Be the first to review this
                                        listing!
                                    </p>
                                    <% } %>

                </ul>
            </div>
            <hr />
            <h3>Feedback</h3>
            <form action="/listings/<%= listing._id %>/feedback" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username:</label>
                    <input type="text" class="form-control" id="username" name="review[username]" required>
                    <div class="invalid-feedback">Please enter your username.</div>
                </div>
                <div class="mb-3">
                    <label for="rating" class="form-label">Rate this listing:</label>
                    <input class="form-range" type="range" id="rating" name="review[rating]" value="0" min="0" max="5">
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Leave a comment:</label>
                    <textarea class="form-control" id="comment" name="review[comment]" required></textarea>
                    <div class="invalid-feedback">Please enter a comment.</div>
                </div>
                <button class="btn btn-dark " type="submit"
                    style="height: 2.3rem; padding: 0.375rem 0.75rem; border-radius: 1rem ;">Submit
                </button>
            </form>





        </div>


    </div>
